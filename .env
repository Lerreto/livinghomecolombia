# Copia este archivo a ".env" y completa los valores reales.
# El .env NO se sube al repositorio (está en el .gitignore).

# --- Traefik / SSL (solo producción) ---
ACME_EMAIL=contact@livinghomecolombia.com

# --- Base de datos de EspoCRM ---
CRM_DB_ROOT_PASSWORD=$(openssl rand -base64 32 | tr -dc 'A-Za-z0-9' | head -c 24)
CRM_DB_NAME=crm
CRM_DB_USER=user_crm
CRM_DB_PASSWORD=$(openssl rand -base64 32 | tr -dc 'A-Za-z0-9' | head -c 24)

# --- Usuario administrador inicial de EspoCRM ---
# Se crea solo en la PRIMERA instalación. Cámbialo luego desde el panel.
CRM_ADMIN_USER=admin
CRM_ADMIN_PASSWORD=LivingHome$(openssl rand -hex 3)